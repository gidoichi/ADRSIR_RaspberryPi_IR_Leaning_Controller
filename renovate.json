{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "branchConcurrentLimit": 0,
  "labels": [
    "dependencies"
  ],
  "schedule": "* 0 1-7 * 6",
  "packageRules": [
    {
      "addLabels": [
        "automerge"
      ],
      "automerge": true,
      "commitMessagePrefix": "ci(deps):",
      "matchFileNames": [
        ".github/**"
      ],
      "recreateWhen": "always"
    },
    {
      "addLabels": [
        "automerge"
      ],
      "automerge": true,
      "commitMessagePrefix": "build(deps):",
      "matchFileNames": [
        "!.github/**"
      ],
      "recreateWhen": "always"
    }
  ]
}
